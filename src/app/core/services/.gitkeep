Destroy Ref (Auto Unsubscribe)
The modern way to avoid memory leaks — no more ngOnDestroy + Subject:

// OLD way — boilerplate heavy
private destroy$ = new Subject<void>();

ngOnInit() {
  this.service.data$.pipe(takeUntil(this.destroy$)).subscribe();
}
ngOnDestroy() {
  this.destroy$.next();
  this.destroy$.complete();
}

// MODERN way — one line
import { takeUntilDestroyed } from '@angular/core/rxjs-interop';

export class BlogListComponent {
  private destroyRef = inject(DestroyRef);

  ngOnInit() {
    this.service.data$
      .pipe(takeUntilDestroyed(this.destroyRef))
      .subscribe();
  }
}












// shared/services/confirm-dialog.service.ts
@Injectable({ providedIn: 'root' })
export class ConfirmDialogService {
  private _visible  = signal(false);
  private _message  = signal('');
  private _resolve!: (result: boolean) => void;

  visible = this._visible.asReadonly();
  message = this._message.asReadonly();

  confirm(message: string): Promise<boolean> {
    this._message.set(message);
    this._visible.set(true);

    return new Promise(resolve => {
      this._resolve = resolve;
    });
  }

  accept(): void { this._resolve(true);  this._visible.set(false); }
  decline(): void { this._resolve(false); this._visible.set(false); }
}

==================================USAGE, SAMPLE ==========================================
// Usage in any component
async onDelete(id: string) {
  const confirmed = await this.confirmDialog.confirm(
    'Are you sure you want to delete this post?'
  );
  if (confirmed) {
    this.store.delete(id).subscribe();
  }
}
=========================================================================================








// core/services/feature-flag.service.ts
@Injectable({ providedIn: 'root' })
export class FeatureFlagService {
  private flags = signal<Record<string, boolean>>({});

  load(flags: Record<string, boolean>): void {
    this.flags.set(flags);
  }

  isEnabled(flag: string): boolean {
    return this.flags()[flag] ?? false;
  }

  // Use in templates
  isEnabled$ = (flag: string) => computed(() => this.flags()[flag] ?? false);
}
==================================USAGE, SAMPLE ==========================================

@if (featureFlags.isEnabled('analytics-dashboard')) {
  <app-analytics-widget />
}
=========================================================================================
